{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${HOME}/projects/portal-5",
        "${HOME}/projects/portal-5/config",
        "${HOME}/projects/portal-5/portal_pipeline",
        "${HOME}/projects/portal-5/portal_mcp",
        "${HOME}/projects/portal-5/portal_channels",
        "${HOME}/projects/portal-5/tests",
        "${HOME}/.portal5/logs",
        "/tmp"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-fetch"]
    },
    "git": {
      "command": "/Users/chris/.local/bin/uvx",
      "args": ["mcp-server-git", "--repository", "/Users/chris/projects/portal-5"]
    },
    "docker": {
      "command": "/opt/homebrew/bin/npx",
      "args": ["-y", "mcp-docker-server"]
    }
  }
}
