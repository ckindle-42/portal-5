{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${HOME}/projects",
        "/tmp"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-fetch"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "${HOME}/projects/portal-5"
      ]
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-docker-server"
      ]
    },
    "portal-comfyui": {
      "type": "http",
      "url": "http://localhost:8910/mcp"
    },
    "portal-video": {
