{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${HOME}/projects/portal-5",
        "${HOME}/projects/portal-5/config",
        "${HOME}/projects/portal-5/portal_pipeline",
        "${HOME}/projects/portal-5/portal_mcp",
        "${HOME}/projects/portal-5/portal_channels",
        "${HOME}/projects/portal-5/tests",
        "${HOME}/.portal5/logs",
        "/tmp"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-fetch"]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "${HOME}/projects/portal-5"
      ]
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-docker"
      ]
    },
    "portal-sandbox": {
      "url": "http://localhost:8914/mcp"
    },
    "portal-pipeline": {
      "url": "http://localhost:8928/mcp"
    }
  }
}
