# Portal 5.0 Configuration
# DO NOT EDIT THIS FILE. Copy to .env — launch.sh does this automatically.
# Secrets marked CHANGEME are auto-generated by ./launch.sh up on first run.

# ── Core secrets (auto-generated on first run) ────────────────────────────────
PIPELINE_API_KEY=CHANGEME
WEBUI_SECRET_KEY=CHANGEME
SEARXNG_SECRET_KEY=CHANGEME
GRAFANA_PASSWORD=CHANGEME

# ── Admin account (created on first fresh Open WebUI start) ──────────────────
# Password is auto-generated on first run and printed to the console.
OPENWEBUI_ADMIN_EMAIL=admin@portal.local
OPENWEBUI_ADMIN_PASSWORD=CHANGEME
OPENWEBUI_ADMIN_NAME=Portal Admin

# ── Multi-User Configuration ──────────────────────────────────────────────────
# Controls who can sign up and what access level they get
# pending: new users need admin approval (RECOMMENDED for team deployments)
# user: new users get immediate access
# admin: new users get admin access (DANGEROUS — do not use in production)
DEFAULT_USER_ROLE=pending

# Set to false to disable self-registration (admin must create accounts manually)
ENABLE_SIGNUP=true

# ── Models ────────────────────────────────────────────────────────────────────
# Pulled automatically on ./launch.sh up
DEFAULT_MODEL=dolphin-llama3:8b
# Set to true to pull 70B parameter models (~35GB each) during pull-models
# Requires 48GB+ RAM and significant disk space
PULL_HEAVY=false

# ── Hardware ──────────────────────────────────────────────────────────────────
COMPUTE_BACKEND=mps       # mps (Apple Silicon) | cuda (NVIDIA) | cpu

# ── Ollama ───────────────────────────────────────────────────────────────────
# Ollama endpoint — where Portal Pipeline reaches the LLM backend
# Default: native Ollama on host (brew install ollama — uses Metal GPU on Apple Silicon)
# Docker mode: set http://ollama:11434 and run: ./launch.sh up --profile docker-ollama
OLLAMA_URL=http://host.docker.internal:11434

# ── MLX — Apple Silicon native inference (optional, 20-40% faster than Ollama on M4) ──
# Install: ./launch.sh install-mlx
# Models:  ./launch.sh pull-mlx-models
# NOTE: MLX_PORT must NOT be 8080 (that's Open WebUI)
MLX_PORT=8081
MLX_MODEL=mlx-community/Qwen3-Coder-Next-4bit
# URL used by Docker containers to reach the native MLX server on the host
MLX_URL=http://host.docker.internal:8081
# Set true for ~1.5x throughput via speculative decoding (mlx-lm>=0.30.5)
# Enabled by default — mlx-lm>=0.30.5 is required in pyproject.toml [apple-silicon].
# Set false only if you see inference errors (incompatible model or older mlx-lm).
MLX_SPECULATIVE=true

# ── Ollama Capacity (tune for your hardware) ──────────────────────────────────
# How many requests Ollama handles simultaneously (default: 4)
# M4 Pro with 48GB: 4 is safe. Reduce if you see OOM errors.
OLLAMA_NUM_PARALLEL=4
# Max models to keep loaded in VRAM simultaneously
OLLAMA_MAX_LOADED_MODELS=2
# Max requests to queue before rejecting (HTTP 503)
OLLAMA_MAX_QUEUE=25
# Docker-only: hard memory cap for the Ollama container (e.g. 48g).
# Set to 0 for unlimited (default). Native Ollama (outside Docker) is unaffected.
OLLAMA_MEMORY_LIMIT=0

# ── Ollama TTFT Tuning (response latency) ─────────────────────────────────────
# keep_alive injected per-request by the Pipeline — how long Ollama holds the
# model in GPU memory after a request finishes. "-1" = never unload (recommended
# for interactive use). Set to "5m" to restore Ollama's built-in default.
# This is separate from OLLAMA_KEEP_ALIVE (server env var) and works for both
# native and Docker Ollama installs.
OLLAMA_KEEP_ALIVE_REQUEST=-1
# Prompt evaluation batch size injected per-request. Larger = faster prefill
# (lower TTFT) on long conversation histories. Ollama default is 512.
# 2048 = ~4x faster prefill; safe for all models in the catalog.
# Reduce to 512 if you see OOM errors on 16GB systems.
OLLAMA_NUM_BATCH=2048

# ── Response preamble / routing visibility ────────────────────────────────────
# When true, the first line of every streaming response shows the workspace and
# model that handled the request — e.g. "⚡ Portal Code Expert → Qwen3-Coder-Next"
# Default: false (clean output). Enable to debug auto-routing decisions or to
# give users visibility into which specialist model is responding.
SHOW_ROUTING_STATUS=false

# ── Pipeline Capacity ─────────────────────────────────────────────────────────
# Number of uvicorn workers (default: min(cpu_count, 4))
# Each worker handles requests independently and maintains its own Ollama health checks
# Set to 1 for accurate aggregate metrics (lower throughput)
# Default min(cpu_count, 4) gives better throughput but per-worker metrics
PIPELINE_WORKERS=2
# Max concurrent LLM requests across all pipeline workers (default: 20)
MAX_CONCURRENT_REQUESTS=20
# Semaphore acquisition timeout in milliseconds (default: 50ms)
# Increase if you see spurious 503s under normal load.
# Set to 0 for original non-blocking behavior (not recommended).
SEMAPHORE_TIMEOUT_MS=50
# Prometheus multiprocess metrics directory (auto-created if unset)
# Set explicitly to a tmpfs path for better performance:
# PROMETHEUS_MULTIPROC_DIR=/dev/shm/portal_metrics

# Pipeline retry configuration for channel adapters (Telegram, Slack)
PIPELINE_RETRIES=3           # Number of retry attempts on transient errors
PIPELINE_RETRY_BASE=1.0      # Base delay in seconds (doubles each retry: 1s, 2s, 4s)

# ── Advanced / Operator Overrides ─────────────────────────────────────────────
# Pipeline server port (default: 9099). Change only if port conflicts occur.
PIPELINE_PORT=9099
# Pipeline URL used by channel adapters (Telegram/Slack) to reach the Pipeline.
# Default is the Docker service name. Override for non-Docker channel adapters.
PIPELINE_URL=http://portal-pipeline:9099
# Timeout in seconds for channel adapter → Pipeline requests (default: 120)
PIPELINE_TIMEOUT=120
# Override path to backends.yaml (default: auto-detected relative to repo root)
# Useful for cluster operators who store config outside the repo.
# BACKEND_CONFIG_PATH=/etc/portal5/backends.yaml
# Prometheus multiprocess metrics directory — set to a tmpfs path for performance.
# PROMETHEUS_MULTIPROC_DIR=/dev/shm/portal_metrics
# ComfyUI model download destination (default: /models/checkpoints in Docker)
# MODELS_DIR=/opt/ComfyUI/models/checkpoints

# ── Output Directory ─────────────────────────────────────────────────────────
# Where generated files (images, audio, video, documents) are saved
AI_OUTPUT_DIR=${HOME}/AI_Output

# ── Generation ───────────────────────────────────────────────────────────────
# ComfyUI endpoint — install natively for Metal GPU: ./launch.sh install-comfyui
# Docker mode: set http://comfyui:8188 and run with --profile docker-comfyui
COMFYUI_URL=http://host.docker.internal:8188
TTS_BACKEND=kokoro             # kokoro (default) | fish_speech
# Default kokoro-onnx voice for text-to-speech
# Options: af_heart, af_sky, af_bella, af_nicole, af_sarah (female American)
#          am_adam, am_michael (male American)
#          bf_emma, bf_isabella (female British)
#          bm_george, bm_lewis (male British)
TTS_DEFAULT_VOICE=af_heart
# Music generation model size for AudioCraft MusicGen
# Options: small (~300MB) | medium (~1.5GB, default) | large (~7GB) | stable-audio (~3GB, higher quality)
MUSIC_MODEL_SIZE=medium
# Maximum number of generated music files to retain (older files auto-deleted)
MAX_MUSIC_FILES=20
SANDBOX_TIMEOUT=30

# ── Image Generation ──────────────────────────────────────────────────────────
# Image model to download on first run for ComfyUI
# Options: flux-schnell (default, ~12GB) | flux-dev (~24GB, needs HF_TOKEN)
#          flux-uncensored (~24GB) | sdxl (~7GB) | juggernaut-xl (~7GB)
#          pony-diffusion (~12GB) | epicrealism-xl (~12GB)
IMAGE_MODEL=flux-schnell
# Video model to download on first run for ComfyUI
# Options: wan2.2 (default, ~18GB) | wan2.2-uncensored (~20GB) | skyreels-v1 (~15GB)
#          mochi-1 (~15GB) | stable-video-diffusion (~10GB)
VIDEO_MODEL=wan2.2
# Wan2.2 model filename in ComfyUI's unet models directory.
# After downloading, run: docker exec portal5-comfyui ls /opt/ComfyUI/models/unet/
# (or: ls ~/ComfyUI/models/unet/ for native installs)
# Set this to match the actual .safetensors filename found.
WAN22_MODEL_FILE=wan2.2_ti2v_5B_fp16.safetensors
WAN22_CLIP_FILE=clip_l.safetensors
WAN22_VAE_FILE=wan2.2_vae.safetensors
# ComfyUI torch device: cpu (works everywhere) | cuda (NVIDIA GPU) | mps (Apple Silicon)
CF_TORCH_DEVICE=cpu

# ── Optional: Telegram ────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_USER_IDS=123456789,987654321
# Default workspace when no /workspace command has been used
# Options: auto, auto-coding, auto-security, auto-redteam, auto-blueteam,
#          auto-creative, auto-reasoning, auto-documents, auto-video,
#          auto-music, auto-research, auto-vision, auto-data
TELEGRAM_DEFAULT_WORKSPACE=auto

# ── Optional: Slack ───────────────────────────────────────────────────────────
# Create at: https://api.slack.com/apps
# Enable Socket Mode and generate an App-Level Token (xapp-...)
SLACK_ENABLED=false
# SLACK_BOT_TOKEN=xoxb-...        (Bot User OAuth Token)
# SLACK_APP_TOKEN=xapp-...        (App-Level Token — required for Socket Mode)
# SLACK_SIGNING_SECRET=...
# Default workspace for DMs and unmapped channels
# Options: same as TELEGRAM_DEFAULT_WORKSPACE above
SLACK_DEFAULT_WORKSPACE=auto

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── HuggingFace (optional, for gated models) ──────────────────────────────────
# HF_TOKEN=hf_...

# ── MCP Port Overrides ───────────────────────────────────────────────────────
# Uncomment and change only if a port is already in use on your host.
#WHISPER_HOST_PORT=8915
#TTS_HOST_PORT=8916
#DOCUMENTS_HOST_PORT=8913
#MUSIC_HOST_PORT=8912
#COMFYUI_MCP_HOST_PORT=8910
#VIDEO_MCP_HOST_PORT=8911
#SANDBOX_HOST_PORT=8914
