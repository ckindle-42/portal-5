{
  "id": null,
  "uid": "portal5-overview",
  "title": "Portal 5 Overview",
  "tags": ["portal5"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 6,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Healthy Backends",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "targets": [{ "expr": "portal_backends_healthy", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Backends",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "targets": [{ "expr": "portal_backends_total", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Workspaces",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "targets": [{ "expr": "portal_workspaces_total", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pipeline Uptime",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "targets": [{ "expr": "portal_uptime_seconds", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 26,
      "type": "stat",
      "title": "Peak Concurrent Requests",
      "description": "Maximum concurrent requests since pipeline started.",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "targets": [{ "expr": "max_over_time(portal_concurrent_requests[1h])", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "options": { "reduceOptions": { "calcs": ["max"] } }
    },
    {
      "id": 27,
      "type": "stat",
      "title": "Current Concurrent",
      "description": "Requests currently being processed.",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "targets": [{ "expr": "portal_concurrent_requests", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 28,
      "type": "stat",
      "title": "Total Requests (session)",
      "description": "Cumulative requests since pipeline restart.",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "targets": [{ "expr": "sum(portal_requests_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 29,
      "type": "stat",
      "title": "Total Errors (session)",
      "description": "Cumulative failed requests since pipeline restart.",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "targets": [{ "expr": "sum(portal_errors_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Backend Health Over Time",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
      "targets": [
        { "expr": "portal_backends_healthy", "legendFormat": "Healthy", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "portal_backends_total", "legendFormat": "Total", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Concurrent Requests Over Time",
      "description": "How many requests are being processed simultaneously.",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
      "targets": [{ "expr": "portal_concurrent_requests", "legendFormat": "Active", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Error Rate by Type",
      "description": "Failed requests per minute broken down by error type.",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 4 },
      "targets": [{ "expr": "rate(portal_errors_total[5m]) * 60", "legendFormat": "{{error_type}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "last"] } }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Model Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tokens Per Second by Model",
      "description": "Rolling average tokens/sec for each model. Higher = faster inference.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "targets": [{ "expr": "rate(portal_tokens_per_second_sum[5m]) / rate(portal_tokens_per_second_count[5m])", "legendFormat": "{{model}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "lineWidth": 2 }, "displayName": "${__field.labels.model}" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Requests by Model (rate/min)",
      "description": "Which models are being called and how often.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "targets": [{ "expr": "rate(portal_requests_by_model_total[5m]) * 60", "legendFormat": "{{model}} ({{workspace}})", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "last"] } }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Avg Tokens/sec (Aggregate)",
      "description": "Average tokens generated per second across all models.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 19 },
      "targets": [{       "expr": "sum(portal_tokens_per_second_sum) / sum(portal_tokens_per_second_count)", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Total Output Tokens",
      "description": "Cumulative output tokens since pipeline restart.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 19 },
      "targets": [{ "expr": "sum(portal_output_tokens_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Total Input Tokens",
      "description": "Cumulative prompt tokens processed since pipeline restart.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 19 },
      "targets": [{ "expr": "sum(portal_input_tokens_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Token Ratio (out/in)",
      "description": "Output tokens per input token. Higher = more verbose models.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 19 },
      "targets": [{ "expr": "sum(portal_output_tokens_total) / sum(portal_input_tokens_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "orange" } } }
    },
    {
      "id": 23,
      "type": "barchart",
      "title": "Top 10 Models by Request Count",
      "description": "Which models are handling the most requests this session.",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 19 },
      "targets": [{ "expr": "topk(10, sum by(model) (portal_requests_by_model_total))", "legendFormat": "{{model}}", "datasource": { "type": "prometheus", "uid": "prometheus" }, "instant": true }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Usage Analytics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Requests by Workspace Over Time",
      "description": "Request rate (req/min) per workspace over time.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [{ "expr": "rate(portal_requests_total[5m]) * 60", "legendFormat": "{{workspace}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] } }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Current Request Rate",
      "description": "Aggregate request throughput across all workspaces (req/min).",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "targets": [{ "expr": "sum(rate(portal_requests_total[5m])) * 60", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "reqpm", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 32,
      "type": "barchart",
      "title": "Error Distribution by Workspace",
      "description": "Which workspaces are experiencing the most errors.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "targets": [{ "expr": "topk(10, sum by(workspace) (portal_errors_total))", "legendFormat": "{{workspace}}", "datasource": { "type": "prometheus", "uid": "prometheus" }, "instant": true }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Tokens by Workspace",
      "description": "Output token generation rate per workspace (tokens/sec).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [{ "expr": "sum by(workspace) (rate(portal_output_tokens_total[5m]))", "legendFormat": "{{workspace}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] } }
    },
    {
      "id": 16,
      "type": "barchart",
      "title": "Top 10 Workspaces by Volume",
      "description": "Top 10 workspaces by request count over the selected time range.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "targets": [{ "expr": "topk(10, sum by(workspace) (increase(portal_requests_total[$__range])))", "legendFormat": "{{workspace}}", "datasource": { "type": "prometheus", "uid": "prometheus" }, "instant": true }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "orientation": "auto", "displayLabels": ["name", "value"], "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Model Distribution per Workspace",
      "description": "Which models are handling each workspace — shows model switching behavior.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "targets": [{ "expr": "topk(10, sum by(workspace, model) (rate(portal_requests_by_model_total[5m])) * 60)", "legendFormat": "{{workspace}} → {{model}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } }
    },
    {
      "id": 33,
      "type": "barchart",
      "title": "Persona Usage (Top 10)",
      "description": "Most used personas/model presets selected by users.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "targets": [{ "expr": "topk(10, sum by(persona) (persona_usage_total))", "legendFormat": "{{persona}}", "datasource": { "type": "prometheus", "uid": "prometheus" }, "instant": true }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "orientation": "horizontal", "displayLabels": ["name", "value"], "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 19,
      "type": "row",
      "title": "Latency & Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Avg Response Time by Model",
      "description": "Average end-to-end response time per model. Lower is better.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "targets": [{ "expr": "rate(portal_response_time_seconds_sum[5m]) / rate(portal_response_time_seconds_count[5m]) * 1000", "legendFormat": "{{model}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Response Time Percentiles (p50 / p95 / p99)",
      "description": "End-to-end latency distribution across all requests.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(portal_response_time_seconds_bucket[5m])) * 1000", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.95, rate(portal_response_time_seconds_bucket[5m])) * 1000", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.99, rate(portal_response_time_seconds_bucket[5m])) * 1000", "legendFormat": "p99", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } }
    },
    {
      "id": 12,
      "type": "barchart",
      "title": "Top Models by Output Tokens",
      "description": "Which models have generated the most tokens this session.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "targets": [{ "expr": "topk(10, sum by(model) (portal_output_tokens_total))", "legendFormat": "{{model}}", "datasource": { "type": "prometheus", "uid": "prometheus" }, "instant": true }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "Tokens Per Second by Workspace",
      "description": "Rolling average tokens/sec per workspace. Shows which workspaces drive inference load.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "targets": [{ "expr": "sum by(workspace) (rate(portal_tokens_per_second_sum[5m])) / sum by(workspace) (rate(portal_tokens_per_second_count[5m]))", "legendFormat": "{{workspace}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] } }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "datasource": { "type": "prometheus", "uid": "prometheus" }
}
