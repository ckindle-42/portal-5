# Agent task files
coding_task/

# Test outputs (bench_tps, matrix driver, UAT driver)
tests/benchmarks/results/
tests/fixtures/audio/

# Stage 2 propose/prove staged diffs + report — working dir, not source
portal/modules/security/core/stage2_proposals/

# Test fixtures generated locally
tests/fixtures/sample.wav

# UAT response corpus — run artifacts; schema doc README.md is tracked
tests/uat_corpus/*.jsonl
tests/uat_corpus/*.json
config/proxmox_ca.pem

# lab_discover.py output — live host state snapshot, not source
/lab_discovery.json
portal/modules/security/core/results/candidates/

# Raw red/blue/purple evidence captures (siem/capture_store.py) — voluminous,
# ephemeral, locally-generated; replayable from Splunk or a fresh run, not source
portal/modules/security/core/results/captures/

# bench_security run outputs (sec_bench_*.json/.partial.json) — ephemeral,
# locally-generated per-run artifacts, not source. Findings belong in
# config/MODEL_CATALOG.md / KNOWN_LIMITATIONS.md, not as committed JSON blobs.
portal/modules/security/core/results/*.json

# Provenance ledger (portal_wiki/core/provenance_ledger.py) — append-only local
# audit trail, grows with every run/write-back; durable on disk, not source-
# controlled (same pattern as metrics_state.json in portal_pipeline).
portal_wiki/provenance_ledger.jsonl

# Compliance/framework posture reports (bench_security/compliance_report.py) —
# ephemeral, per-run, rendered fresh from grounded results; not source.
/reports/

# Runtime supervisor state — regenerates every run, not source.
/supervisor_log.json
