FROM python:3.11-slim

WORKDIR /app

# System deps for document generation and audio
RUN apt-get update && apt-get install -y --no-install-recommends \
    libmagic1 \
    ffmpeg \
    curl \
    espeak-ng \
    libespeak-ng1 \
    && rm -rf /var/lib/apt/lists/*

# Core deps
RUN pip install --no-cache-dir \
    "fastapi>=0.109.0" \
    "uvicorn[standard]>=0.27.0" \
    "httpx>=0.26.0" \
    "pyyaml>=6.0.1" \
    "starlette>=0.35.0"

# MCP SDK — required by ALL portal_mcp servers
# fastmcp (vendored in portal_mcp/mcp_server/) depends on the mcp package
RUN pip install --no-cache-dir \
    "mcp>=1.0.0" \
    "fastmcp>=0.4.0"

# Document generation
RUN pip install --no-cache-dir \
    "python-docx>=1.1.0" \
    "python-pptx>=0.6.23" \
    "openpyxl>=3.1.0" \
    "markdown>=3.6"

# Audio / speech — kokoro-onnx is zero-setup, fish-speech optional
RUN pip install --no-cache-dir \
    "faster-whisper>=1.0.0" \
    "kokoro-onnx>=0.4.0" \
    "soundfile>=0.12.1" \
    "numpy>=1.24.0" \
    "huggingface_hub>=0.20.0"

# AudioCraft + Stable Audio — NOT supported on aarch64 Linux (missing torchtext==0.16.0, xformers build failures).
# music_mcp degrades gracefully with a helpful error message. Install on x86_64+CUDA host if needed.

# Channel adapters (Telegram + Slack) — used by portal-telegram, portal-slack
RUN pip install --no-cache-dir \
    "python-telegram-bot>=20.7" \
    "slack-bolt>=1.18.0"

# Copy application
COPY portal_mcp/ ./portal_mcp/
COPY portal_channels/ ./portal_channels/

# Run as non-root user
RUN groupadd -r portal && useradd -r -g portal portal \
    && chown -R portal:portal /app
USER portal

# No HEALTHCHECK here — defined per-service in docker-compose.yml

CMD ["python", "-m", "portal_mcp.documents.document_mcp"]
