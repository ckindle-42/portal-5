# Stage 0: pull the docker CLI binary (for code sandbox DinD connectivity)
FROM docker:27-cli AS docker-cli

FROM python:3.11-slim

WORKDIR /app

# docker CLI binary — needed by code_sandbox_mcp to connect to DinD
COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker

# System deps for document generation and audio
# openssh-client — needed by the proxmox MCP for host/LXC exec (proxmox_node_exec /
# proxmox_container_exec shell out to `ssh`); harmless elsewhere in the shared image.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libmagic1 \
    ffmpeg \
    curl \
    espeak-ng \
    libespeak-ng1 \
    openscad \
    libosmesa6 \
    libgl1 \
    libglib2.0-0 \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Core deps
RUN pip install --no-cache-dir \
    "fastapi>=0.109.0" \
    "uvicorn[standard]>=0.27.0" \
    "httpx>=0.26.0" \
    "pyyaml>=6.0.1" \
    "starlette>=0.35.0"

# MCP SDK — required by ALL portal_mcp servers
# fastmcp (vendored in portal_mcp/mcp_server/) depends on the mcp package
RUN pip install --no-cache-dir \
    "mcp>=1.0.0" \
    "fastmcp>=0.4.0"

# Document generation
RUN pip install --no-cache-dir \
    "python-docx>=1.1.0" \
    "python-pptx>=0.6.23" \
    "openpyxl>=3.1.0" \
    "pdfplumber>=0.11.0" \
    "markdown>=3.6"

# Audio / speech — kokoro-onnx is zero-setup, fish-speech optional
# pyannote.audio added for transcribe_with_speakers (TASK-TRANSCRIBE-001)
RUN pip install --no-cache-dir \
    "faster-whisper>=1.0.0" \
    "kokoro-onnx>=0.4.0" \
    "soundfile>=0.12.1" \
    "numpy>=1.24.0" \
    "huggingface_hub>=0.20.0" \
    "pyannote.audio>=3.1.0"

# Music generation via HuggingFace transformers (MusicGen — facebook/musicgen-*)
# Works on aarch64 Linux (CPU), macOS (MPS), and Linux x86_64 (CUDA).
# AudioCraft is NOT used — it requires torchtext==0.16.0 and xformers which have no aarch64 wheels.
# torch CPU wheels for aarch64 Linux are available from PyPI since PyTorch 2.1.
RUN pip install --no-cache-dir \
    "torch>=2.1.0" \
    "torchaudio>=2.1.0" \
    "transformers>=4.40.0" \
    "scipy>=1.11.0"

# Vector storage + retrieval (memory MCP, RAG MCP)
RUN pip install --no-cache-dir \
    "lancedb>=0.13.0" \
    "pyarrow>=18.0.0" \
    "pypdf>=4.0.0" \
    "docling>=2.0.0"

# Pre-fetch Docling layout/TableFormer model weights at build time (best-effort).
RUN docling-tools models download \
    || python3 -c "from docling.utils.model_downloader import download_models; download_models()" \
    || echo "WARN: docling model prefetch failed; models will download at first use"

# CAD render MCP deps — headless mesh rendering + format conversion
RUN pip install --no-cache-dir \
    "trimesh[easy]>=4.0.0" \
    "pyrender>=0.1.45" \
    "matplotlib>=3.8.0" \
    "numpy>=1.26.0"

# Code-CAD geometry libs — trimesh + numpy-stl for procedural STL generation in Python.
# Note: CadQuery/build123d require OCP (OpenCASCADE Python bindings) which has no
# pre-built arm64 wheels; they cannot be installed on linux/arm64 without a source
# build. Primary code-CAD path on this platform is OpenSCAD (via render_openscad tool).
RUN pip install --no-cache-dir \
    "numpy-stl>=3.0.0"

# Channel adapters (Telegram + Slack) — used by portal-telegram, portal-slack
RUN pip install --no-cache-dir \
    "python-telegram-bot>=20.7" \
    "slack-bolt>=1.18.0"

# Copy application
# portal_mcp/core and portal_mcp/security are now compat shims re-exporting
# from portal/platform/mcp_host and portal/modules/security/tools
# (BUILD-SPEC-PORTAL-MODULES-V1) — both must be present until shims removed.
COPY portal_mcp/ ./portal_mcp/
COPY portal_channels/ ./portal_channels/
COPY portal/__init__.py ./portal/__init__.py
COPY portal/platform/ ./portal/platform/
COPY portal/modules/ ./portal/modules/
COPY scripts/mcp-entrypoint.sh /usr/local/bin/mcp-entrypoint.sh

# Create non-root user (with a home dir — needed so the entrypoint can stage a
# private SSH key for the proxmox MCP at portal-owned, correctly-permissioned
# paths); entrypoint fixes volume mount ownership at runtime then drops to this user
RUN groupadd -r portal && useradd -r -m -g portal portal \
    && mkdir -p /app/data/hf_cache /app/data/generated /home/portal/.ssh \
    && chown -R portal:portal /app /home/portal \
    && chmod 700 /home/portal/.ssh \
    && chmod +x /usr/local/bin/mcp-entrypoint.sh

# No HEALTHCHECK here — defined per-service in docker-compose.yml

ENTRYPOINT ["/usr/local/bin/mcp-entrypoint.sh"]
CMD ["python", "-m", "portal_mcp.documents.document_mcp"]
