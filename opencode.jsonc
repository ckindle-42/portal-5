// opencode project configuration — Portal 5
// Tells opencode to use portal-pipeline (:9099) as the local AI provider
// instead of Anthropic's cloud. All inference stays on this machine.
//
// Prerequisites:
//   1. Stack running: ./launch.sh up
//   2. PIPELINE_API_KEY exported: export $(grep PIPELINE_API_KEY .env | xargs)
//   3. opencode installed: ~/.opencode/bin/opencode .
//
// ALIAS-RETIREMENT CLOSEOUT (CLOSEOUT_ALIAS_REMOVAL.md,
// DESIGN_OPENCODE_ADDRESSING_V1.md): the "models" block below is keyed on
// persona slugs for every variant entry, and bare workspace ids for base
// entries — the pre-collapse alias ids (auto-coding-agentic, auto-redteam,
// etc.) are retired. opencode sends the key verbatim as the request's
// "model" field; a plain persona-slug string (no "::") transmits cleanly
// with zero risk of client-side mangling, unlike a "base::variant"
// synthetic id. A persona is the friendly named binding of
// (workspace + variant) — exactly what a curated picker entry needs.
// pipeline_mcp.py's get_workspace_recommendation() returns matching
// persona slugs / base ids for the same reason — keep both in sync.
//
// Migration table (old alias key -> new picker key):
//   auto-coding-agentic          -> codingagentic   (persona, opencode default)
//   auto-agentic                 -> agenticheavy    (persona)
//   auto-agentic-lite            -> agenticlite     (persona)
//   auto-coding-uncensored       -> codinguncensored         (persona)
//   auto-coding-uncensored-agentic -> codinguncensoredagentic (persona)
//   auto-pentest                 -> pentestlead     (persona)
//   auto-redteam                 -> pentester       (persona)
//   auto-blueteam                -> blueteamdefender (persona)
//   auto-purpleteam               -> purpleteamlead  (persona)
//   auto-purpleteam-exec          -> purpleteamexec  (persona)
//   auto-security-uncensored      -> securityuncensored (persona)
//   (all other keys unchanged — base workspace ids)
//
// Models available: the curated 20 below, or the full ~138-persona +
// 21-workspace catalog via `opencode models` (GET /v1/models advertises
// every ide_expose: true persona alongside all base workspaces).
// Default model: portal/codingagentic  →  Laguna-XS.2 (Poolside AI 33B-A3B MoE, 68.2% SWE-bench Verified).
// Uncensored lanes (explicit pick): codinguncensored (one-shot),
// codinguncensoredagentic (agentic), auto-general-uncensored (generalist).
// Not defaults — select deliberately. Also: auto-extract-uncensored and
// securityuncensored exist outside this picker (full list via `opencode models`).
{
  "$schema": "https://opencode.ai/config.json",

  // ── Local inference provider ───────────────────────────────────────────────
  "provider": {
    "portal": {
      "name": "Portal 5 (local)",
      "api": "openai",
      // opencode reads PIPELINE_API_KEY from the environment and passes it as
      // the Bearer token. Before running opencode, export the key:
      //   export $(grep PIPELINE_API_KEY .env | xargs)
      "env": ["PIPELINE_API_KEY"],
      "options": {
        "baseURL": "http://localhost:9099/v1"
      },
      // Curated workspace subset for coding tasks — use `opencode models`
      // to see all 90 or select any workspace from the model picker.
      "models": {

        // ── General ───────────────────────────────────────────────────────────
        "auto-daily": {
          "name": "Portal · Daily Driver (Gemma 4 26B QAT)",
          "attachment": true,
          "reasoning": false
        },
        "auto-reasoning": {
          "name": "Portal · Deep Reasoner (DeepSeek-R1-0528 8B)",
          "attachment": true,
          "reasoning": true
        },
        "auto-research": {
          "name": "Portal · Research Assistant (web-augmented)",
          "attachment": true,
          "reasoning": false
        },
        "auto-data": {
          "name": "Portal · Data Analyst (Qwen3.6-27B)",
          "attachment": true,
          "reasoning": false
        },

        // ── Coding ────────────────────────────────────────────────────────────
        "auto-coding": {
          "name": "Portal · Code Expert (Qwen3-Coder 30B, one-shot)",
          "attachment": true,
          "reasoning": false
        },
        "codingagentic": {
          "name": "Portal · IDE Agentic (Laguna-XS.2 33B, opencode default)",
          "attachment": true,
          "reasoning": false
        },
        "agenticheavy": {
          "name": "Portal · Agentic Heavy (Qwen3-Coder-Next 80B + AgentWorld 35B fallback)",
          "attachment": true,
          "reasoning": false
        },
        "agenticlite": {
          "name": "Portal · Agentic Lite (AgentWorld 35B, 45 t/s, MCP/SWE/Terminal)",
          "attachment": true,
          "reasoning": true
        },
        "codinguncensored": {
          "name": "Portal · Code Uncensored (OmniCoder-2 9B, one-shot)",
          "attachment": true,
          "reasoning": false
        },
        "codinguncensoredagentic": {
          "name": "Portal · Agentic Coder Uncensored (Qwen3-Coder-Next abliterated)",
          "attachment": true,
          "reasoning": false
        },

        // ── Security ──────────────────────────────────────────────────────────
        "auto-security": {
          "name": "Portal · Security Analyst (VulnLLM-R-7B)",
          "attachment": true,
          "reasoning": false
        },
        "pentestlead": {
          "name": "Portal · Pentest Assistant (authorized engagements)",
          "attachment": false,
          "reasoning": false
        },
        "pentester": {
          "name": "Portal · Red Team (offensive, authorized)",
          "attachment": false,
          "reasoning": false
        },
        "blueteamdefender": {
          "name": "Portal · Blue Team (defensive, IR, detection)",
          "attachment": true,
          "reasoning": false
        },
        "purpleteamlead": {
          "name": "Portal · Purple Team (TTP analysis)",
          "attachment": true,
          "reasoning": false
        },
        "purpleteamexec": {
          "name": "Portal · Purple Team Exec (tool-calling, live lab)",
          "attachment": false,
          "reasoning": true
        },
        "auto-spl": {
          "name": "Portal · SPL Engineer (Splunk, YARA, detections)",
          "attachment": true,
          "reasoning": false
        },
        "securityuncensored": {
          "name": "Portal · Security Uncensored (no refusals)",
          "attachment": false,
          "reasoning": false
        },

        // ── General uncensored ────────────────────────────────────────────────
        "auto-general-uncensored": {
          "name": "Portal · General Uncensored (Qwen3.6-abliterated 27B)",
          "attachment": true,
          "reasoning": false
        },
        "auto-extract-uncensored": {
          "name": "Portal · Extract Uncensored (structured data parsing)",
          "attachment": true,
          "reasoning": false
        }
      }
    },

    // ── P40 remote Ollama (out-of-band conductor brain) ──────────────────────
    "p40": {
      "name": "P40 (remote local Ollama)",
      "api": "openai",
      "options": {
        "baseURL": "http://10.0.0.204:11434/v1"
      },
      "models": {
        "ducquoc/gpt-oss-sonnet:latest": {
          "name": "P40 · Conductor (gpt-oss-sonnet)",
          "reasoning": true
        }
      }
    }
  },

  // ── Default model for new sessions ────────────────────────────────────────
  "model": "portal/codingagentic",

  // ── Disable built-in cloud providers to prevent accidental cloud use ──────
  "disabled_providers": ["anthropic", "openai", "google", "bedrock", "vertex"],

  // ── Project instructions (loaded alongside CLAUDE.md by opencode) ─────────
  "instructions": ["CLAUDE.md"],

  // ── MCP servers (opencode reads these; .mcp.json is Claude Code format only) ─
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem",
        "/Users/chris/projects",
        "/tmp"
      ]
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-fetch"]
    },
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git", "--repository", "/Users/chris/projects/portal-5"]
    },
    "docker": {
      "type": "local",
      "command": ["npx", "-y", "mcp-docker-server"]
    },
    "portal-comfyui": {
      "type": "remote",
      "url": "http://localhost:8910/mcp"
    },
    "portal-video": {
      "type": "remote",
      "url": "http://localhost:8911/mcp"
    },
    "portal-music": {
      "type": "remote",
      "url": "http://localhost:8912/mcp"
    },
    "portal-documents": {
      "type": "remote",
      "url": "http://localhost:8913/mcp"
    },
    "portal-sandbox": {
      "type": "remote",
      "url": "http://localhost:8914/mcp"
    },
    "portal-whisper": {
      "type": "remote",
      "url": "http://localhost:8915/mcp"
    },
    "portal-tts": {
      "type": "remote",
      "url": "http://localhost:8916/mcp"
    },
    "portal-security": {
      "type": "remote",
      "url": "http://localhost:8919/mcp"
    },
    "portal-memory": {
      "type": "remote",
      "url": "http://localhost:8920/mcp"
    },
    "portal-rag": {
      "type": "remote",
      "url": "http://localhost:8921/mcp"
    },
    "portal-research": {
      "type": "remote",
      "url": "http://localhost:8922/mcp"
    },
    "portal-browser": {
      "type": "remote",
      "url": "http://localhost:8923/mcp"
    },
    "portal-mlx-transcribe": {
      "type": "remote",
      "url": "http://localhost:8924/mcp"
    },
    "portal-proxmox": {
      "type": "remote",
      "url": "http://localhost:8927/mcp"
    },
    "portal-pipeline": {
      "type": "remote",
      "url": "http://localhost:8928/mcp"
    },
    "portal-mitre": {
      "type": "remote",
      "url": "http://localhost:8929/mcp"
    },
    "portal-detections": {
      "type": "remote",
      "url": "http://localhost:8932/mcp"
    },
    "portal-wiki": {
      "type": "remote",
      "url": "http://localhost:8931/mcp"
    }
  }
}
